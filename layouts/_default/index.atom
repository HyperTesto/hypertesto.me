{{- $pctx := . -}}
{{- if .IsHome -}}
    {{- $pctx = .Site -}}
{{- end -}}

{{- $pages := slice -}}
{{- if or $.IsHome $.IsSection -}}
    {{- $pages = $pctx.RegularPages -}}
{{- else -}}
    {{- $pages = $pctx.Pages -}}
{{- end -}}

{{- $limit := .Site.Config.Services.RSS.Limit -}}
{{- if ge $limit 1 -}}
    {{- $pages = $pages | first $limit -}}
{{- end -}}

{{- $pages = (where $pages ".Params.unlisted" "!=" true) -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ .Site.Language.Lang | default "en" }}">
    <title>{{ if eq .Title .Site.Title }}{{ .Site.Title }}{{ else }}{{ with .Title }}{{.}} on {{ end }}{{ .Site.Title }}{{ end }}{{ with .Site.Params.Description }}: {{ . }}{{ end }}</title>
    <link rel="alternate" type="text/html" href="{{ .Permalink }}"/>
    {{- with .OutputFormats.Get "atom" }}
    <link rel="self" type="application/atom+xml" href="{{ .Permalink }}"/>
    {{- else }}
    <link rel="self" type="application/atom+xml" href="{{ .Permalink | html }}index.xml"/>
    {{- end }}
    <subtitle>{{ .Site.Params.Description | default "Recent content" }}</subtitle>
    <id>{{ .Permalink }}</id>
    <generator uri="https://gohugo.io/">Hugo</generator>
    {{- with .Site.Copyright }}
    <rights>{{ . }}</rights>
    {{- end }}
    {{- if not .Date.IsZero }}
    <updated>{{ .Date.Format "2006-01-02T15:04:05Z" | safeHTML }}</updated>
    {{- end }}
    {{- range $pages }}
    <entry>
        <title>{{ .Title }}</title>
        <link rel="alternate" type="text/html" href="{{ .Permalink }}"/>
        <published>{{ .Date.Format "2006-01-02T15:04:05Z" | safeHTML }}</published>
        <updated>{{ .Lastmod.Format "2006-01-02T15:04:05Z" | safeHTML }}</updated>
        <id>{{ .Permalink }}</id>
        {{- with .Site.Params.author }}
        <author>
            <name>{{ .name | default . }}</name>
            {{- with .email }}
            <email>{{ . }}</email>
            {{- end }}
        </author>
        {{- end }}
        <summary type="html">{{ .Summary | html }}</summary>
    </entry>
    {{- end }}
</feed>
